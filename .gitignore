# =========================
# Unity .gitignore
# =========================

# Unity generated folders
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
UserSettings/

# Memory captures
[Mm]emoryCaptures/

# Keep meta files
!/[Aa]ssets/**/*.meta
!/[Pp]ackages/**/*.meta
!/[Pp]rojectSettings/**/*.meta

# Visual Studio / Rider
.vs/
.idea/
.gradle/

*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# OS files
.DS_Store
Thumbs.db

# Unity cache
/[Aa]ssets/AssetStoreTools*

# Builds
*.apk
*.aab
*.unitypackage
*.app
*.exe
*.ipa

# Crash reports
sysinfo.txt

# Addressables
/ServerData

# JetBrains Rider plugin
Assets/Plugins/Editor/JetBrains*
